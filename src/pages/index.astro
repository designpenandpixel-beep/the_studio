---
// CinexAI — AI-powered media production platform v3
import Layout from '../layouts/Layout.astro';
---

<Layout title="CinexAI — AI Media Production Platform">
  <div id="app"></div>

  <div class="stat-bar" id="sbar" style="display:none">
    <div class="stat"><div class="dot dg"></div><span id="st-r">—</span></div>
    <div class="stat"><div class="dot dgr"></div><span id="st-i">0 images</span></div>
    <div class="stat"><div class="dot db"></div><span id="st-v">0 videos</span></div>
    <div class="stat" style="margin-left:auto"><span id="st-m" style="color:var(--t4)"></span></div>
  </div>

  <div id="modal-root"></div>
</Layout>

<script is:inline src="/scripts/app.js"></script>
<script is:inline src="/scripts/post_production.js"></script>
